<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/bg_surface" />
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
        </shape>
    </item>
    <!-- Top neon glow line -->
    <item android:top="0dp" android:bottom="0dp">
        <shape>
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="@color/neon_pink"
                android:centerColor="@color/bg_primary"
                android:endColor="@color/bg_primary" />
            <size android:height="2dp" />
        </shape>
    </item>
</layer-list>
