<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/selector_song_item"
    android:paddingStart="12dp"
    android:paddingEnd="8dp">

    <!-- Playing indicator bar on the left -->
    <View
        android:id="@+id/ivPlayingIndicator"
        android:layout_width="3dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_playing_bar"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Note icon -->
    <ImageView
        android:id="@+id/ivNoteIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_music_note"
        android:tint="@color/icon_music"
        android:background="@drawable/bg_note_icon"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="8dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:fontFamily="@font/orbitron_bold"
        android:textColor="@color/text_primary"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivNoteIcon"
        app:layout_constraintEnd_toStartOf="@id/btnFavorite"
        app:layout_constraintBottom_toTopOf="@id/tvArtist"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginStart="10dp"
        android:layout_marginTop="12dp" />

    <!-- Artist + folder -->
    <TextView
        android:id="@+id/tvArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:fontFamily="@font/orbitron_regular"
        android:textColor="@color/text_secondary"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toEndOf="@id/ivNoteIcon"
        app:layout_constraintEnd_toStartOf="@id/btnFavorite"
        app:layout_constraintBottom_toTopOf="@id/badgeRow"
        android:layout_marginStart="10dp"
        android:layout_marginTop="1dp" />

    <!-- Badge row: folder name, duration, pitch badge, trim badge -->
    <LinearLayout
        android:id="@+id/badgeRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvArtist"
        app:layout_constraintStart_toEndOf="@id/ivNoteIcon"
        app:layout_constraintEnd_toStartOf="@id/btnFavorite"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tvFolder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:textColor="@color/neon_cyan"
            android:fontFamily="@font/orbitron_regular"
            android:maxLines="1"
            android:ellipsize="end"
            android:maxWidth="90dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="10dp"
            android:background="@color/divider_color"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:textColor="@color/text_hint"
            android:fontFamily="@font/orbitron_regular" />

        <!-- Pitch badge -->
        <TextView
            android:id="@+id/tvPitchBadge"
            android:layout_width="wrap_content"
            android:layout_height="16dp"
            android:gravity="center"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:textSize="8sp"
            android:textColor="@color/neon_green"
            android:fontFamily="@font/orbitron_bold"
            android:background="@drawable/bg_pitch_badge"
            android:visibility="gone"
            android:layout_marginStart="6dp" />

        <!-- Trim badge -->
        <ImageView
            android:id="@+id/ivTrimBadge"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_trim"
            android:tint="@color/neon_orange"
            android:visibility="gone"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Favorite button -->
    <ImageButton
        android:id="@+id/btnFavorite"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_heart_outline"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Favorite"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Bottom divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivNoteIcon"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="18dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
